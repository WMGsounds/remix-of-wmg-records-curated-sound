{
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    {
      "source": "/((?!api/.*|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "wmgsounds.com" }],
      "destination": "https://www.wmgsounds.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "wmgr-soundscapes.lovable.app" }],
      "destination": "https://www.wmgsounds.com/$1",
      "permanent": true
    }
  ]
}
